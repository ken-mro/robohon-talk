{
  "name": "robohon-relay-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "RoBoHoN × Claude 中継サーバ (Phase B PoC). 端末からの認識テキストをClaude(Haiku)へ中継し、~150字分割の発話とアプリ連携actionを返す。",
  "scripts": {
    "gen": "node scripts/gen-prompts.mjs",
    "build": "node scripts/gen-prompts.mjs && tsc",
    "start": "node dist/index.js",
    "start:env": "node --env-file=.env dist/index.js",
    "test": "node scripts/gen-prompts.mjs && tsc && node --test \"dist/test/*.test.js\"",
    "cf:dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  }
}